<h1>New game</h1>
<h2>Letters</h2>
<ul>
<% @letters.each do |letter| %>
<li><%= letter.capitalize %></li>
<% end %>
</ul>

<h2>Find a word</h2>
<form action="/score" method="post" data-turbo="false">
  <% @letters.each do |letter| %>
    <%= hidden_field_tag "letters[]", letter %>
  <% end %>

  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <label for="word">Longuest word?</label>
  <input type="text" name="word" id="word" value="<%= params[:word] %>" required>
  <input type="submit" value="Submit">
</form>
